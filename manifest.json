{
  "manifest_version": 3,
  "name": "Chief of Slack",
  "version": "1.0.4",
  "description": "Cut through Slack noise in seconds with custom AI summaries and prioritization",
  "permissions": ["storage", "declarativeNetRequest", "sidePanel"],
  "host_permissions": ["https://app.slack.com/*", "https://*.slack.com/*", "https://api.anthropic.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app.slack.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://app.slack.com/archives/*",
        "https://*.slack.com/archives/*",
        "https://*.slack.com/ssb/redirect*",
        "https://slack.com/app_redirect*",
        "https://*.slack.com/app_redirect*"
      ],
      "js": ["redirect.js"],
      "run_at": "document_start"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Period",
        "mac": "Command+Period"
      }
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js", "standard-emoji.json", "content.css"],
      "matches": ["https://app.slack.com/*"]
    },
    {
      "resources": ["block-slack-protocol.js"],
      "matches": ["https://*.slack.com/*"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  },
  "options_page": "options.html",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Chief of Slack",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
